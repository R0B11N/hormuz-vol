# Copy to .env in this directory and fill in.
# Polymarket CLOB /prices-history needs the YES-outcome token id (long digits), not the URL slug.
# Option A — paste token id from Gamma (field clobTokenIds → first id = Yes):
#   https://gamma-api.polymarket.com/markets/slug/<your-slug>
POLYMARKET_YES_TOKEN_ID=
# Option B — slug only (code resolves via Gamma); must match an active market:
POLYMARKET_SLUG=iran-israel-ceasefire-2026
# If the market has more than two outcomes, pick index (usually 0 = Yes):
POLYMARKET_OUTCOME_INDEX=0

# Google BigQuery for GDELT (optional):
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
